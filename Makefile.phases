# 📦 Автоматически сгенерированные фазовые цели

# 🔧 Фаза: arca_core
arca_core_objects = phase_utils.o phase_types.o
arca_core_build: $(arca_core_objects)
	@echo '✅ Сборка arca_core завершена.'

phase_utils.o: arca_core/src/phase_utils.cpp
	g++ -std=c++23 -Wall -Wextra -O2 -I/usr/include/boost -DBOOST_ALL_NO_LIB -c $< -o $@

phase_types.o: arca_core/src/phase_types.cpp
	g++ -std=c++23 -Wall -Wextra -O2 -I/usr/include/boost -DBOOST_ALL_NO_LIB -c $< -o $@
