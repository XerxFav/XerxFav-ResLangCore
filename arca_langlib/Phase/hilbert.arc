module Phase.Hilbert:

  # ------------------------------------------------------------
  # 1. Скалярное произведение
  # ------------------------------------------------------------
  operator inner_product:
    input:
      - f: Function
      - g: Function
      - a: Real
      - b: Real
    output:
      - I: Real
    description:
      "Скалярное произведение в пространстве L2[a,b]."


  # ------------------------------------------------------------
  # 2. Норма функции
  # ------------------------------------------------------------
  operator norm:
    input:
      - f: Function
      - a: Real
      - b: Real
    output:
      - N: Real
    description:
      "Норма функции в L2."


  # ------------------------------------------------------------
  # 3. Ортогональная проекция
  # ------------------------------------------------------------
  operator projection:
    input:
      - f: Function
      - g: Function
      - a: Real
      - b: Real
    output:
      - proj: Function
    description:
      "Ортогональная проекция f на g."
